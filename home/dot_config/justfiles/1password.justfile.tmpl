# --------------------
# 1Password CLI recipes
# --------------------
set quiet
set dotenv-load := false
set export := true

justfile := justfile_directory() + "/.justfiles/1password.justfile"

# list all available recipes
[private]
@default:
    just --justfile {{ "{{" }} justfile {{ "}}" }} --list

# format this justfile
[private]
@fmt:
    just --justfile {{ "{{" }} justfile {{ "}}" }} --fmt

# Add a new 1Password account
[group("setup")]
[group("auth")]
[script("bash")]
add-account:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Add 1Password Account"
    echo "====================="
    echo ""
    echo "Enter your 1Password account details:"
    echo ""
    read -r -p "Account shorthand (e.g., 'my'): " shorthand
    read -r -p "Account address (e.g., 'my.1password.com'): " address
    read -r -p "Email address: " email
    echo ""
    op account add --shorthand "$shorthand" --address "$address" --email "$email"
    echo ""
    echo "Account added successfully!"
    echo "Sign in with: just 1p signin"

# Sign in to 1Password
[group("auth")]
[script("bash")]
signin:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Signing in to 1Password..."
    eval "$(op signin)"
    echo "✓ Signed in successfully!"

# Sign out of 1Password
[group("auth")]
[script("bash")]
signout:
    #!/usr/bin/env bash
    set -euo pipefail
    op signout
    echo "✓ Signed out successfully!"

# List configured accounts
[group("info")]
[script("bash")]
accounts:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "1Password Accounts"
    echo "=================="
    echo ""
    op account list --format json | jq -r '.[] | "• \(.shorthand) (\(.email)) - \(.url)"'

# Show current user info
[group("info")]
[script("bash")]
whoami:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Current 1Password User"
    echo "======================"
    echo ""
    op user get --me | jq '{name: .name, email: .email, state: .state}'

# List all vaults
[group("vault")]
[script("bash")]
vaults:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "1Password Vaults"
    echo "================"
    echo ""
    op vault list --format json | jq -r '.[] | "• \(.name) (\(.id))"'

# List items in a vault
[group("vault")]
[script("bash")]
list vault:
    #!/usr/bin/env bash
    set -euo pipefail
    op item list --vault "{{ "{{" }} vault {{ "}}" }}" --format json | jq -r '.[] | "• \(.title) (\(.id))"'

# Get an item by name or ID
[group("vault")]
[script("bash")]
get item:
    #!/usr/bin/env bash
    set -euo pipefail
    op item get "{{ "{{" }} item {{ "}}" }}" --format json | jq '.'

# Get a specific field from an item
[group("vault")]
[script("bash")]
get-field item field:
    #!/usr/bin/env bash
    set -euo pipefail
    op item get "{{ "{{" }} item {{ "}}" }}" --field "{{ "{{" }} field {{ "}}" }}"

# Get a password from an item
[group("vault")]
[script("bash")]
get-password item:
    #!/usr/bin/env bash
    set -euo pipefail
    op item get "{{ "{{" }} item {{ "}}" }}" --field password --reveal

# Get a username from an item
[group("vault")]
[script("bash")]
get-username item:
    #!/usr/bin/env bash
    set -euo pipefail
    op item get "{{ "{{" }} item {{ "}}" }}" --field username

# Create a new login item
[group("vault")]
[script("bash")]
create-login vault title username password:
    #!/usr/bin/env bash
    set -euo pipefail
    op item create --vault "{{ "{{" }} vault {{ "}}" }}" \
        --category login \
        --title "{{ "{{" }} title {{ "}}" }}" \
        username="{{ "{{" }} username {{ "}}" }}" \
        password="{{ "{{" }} password {{ "}}" }}"
    echo "✓ Login item created: {{ "{{" }} title {{ "}}" }}"

# Create a new secure note
[group("vault")]
[script("bash")]
create-note vault title:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Enter note content (Ctrl+D to finish):"
    NOTE_CONTENT=$(cat)
    op item create --vault "{{ "{{" }} vault {{ "}}" }}" \
        --category secure-note \
        --title "{{ "{{" }} title {{ "}}" }}" \
        notes="$NOTE_CONTENT"
    echo "✓ Secure note created: {{ "{{" }} title {{ "}}" }}"

# Delete an item
[group("vault")]
[script("bash")]
delete item:
    #!/usr/bin/env bash
    set -euo pipefail
    read -r -p "Delete '{{ "{{" }} item {{ "}}" }}'? This cannot be undone. (y/N) " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        op item delete "{{ "{{" }} item {{ "}}" }}"
        echo "✓ Item deleted: {{ "{{" }} item {{ "}}" }}"
    else
        echo "Cancelled."
    fi

# Read a secret using 1Password reference
[group("vault")]
[script("bash")]
read reference:
    #!/usr/bin/env bash
    set -euo pipefail
    op read "{{ "{{" }} reference {{ "}}" }}"

# Get a document by ID
[group("vault")]
[script("bash")]
get-document document-id output:
    #!/usr/bin/env bash
    set -euo pipefail
    op document get "{{ "{{" }} document-id {{ "}}" }}" --output "{{ "{{" }} output {{ "}}" }}"
    echo "✓ Document saved to: {{ "{{" }} output {{ "}}" }}"

# Sync vault (if using 1Password Connect)
[group("vault")]
[script("bash")]
sync:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Note: 1Password automatically syncs when connected."
    echo "Use 'op item get --refresh' to force refresh specific items."

# Show 1Password CLI version
[group("info")]
[script("bash")]
version:
    #!/usr/bin/env bash
    set -euo pipefail
    op --version

# Enable biometric authentication (macOS only)
{{- if eq .chezmoi.os "darwin" }}
[group("setup")]
[script("bash")]
enable-biometric:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Enabling biometric authentication..."
    echo ""
    echo "To enable biometric authentication:"
    echo "  1. Open 1Password desktop app"
    echo "  2. Go to Preferences > Developer"
    echo "  3. Enable 'Touch ID' or 'Biometric unlock'"
    echo "  4. Run: op signin --biometric"
    echo ""
    echo "After enabling, you can use 'op signin --biometric' to authenticate"
    echo "without entering your master password."
{{- end }}