{
  // =====================================================================================
  // WINDOW & WORKBENCH
  // =====================================================================================
  "window.commandCenter": true,
  "window.density.editorTabHeight": "compact",
  "workbench.activityBar.orientation": "vertical",
  "workbench.colorTheme": "One Dark Pro Mix",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.settings.editor": "json",
  "workbench.tree.enableStickyScroll": true,
  "workbench.tree.indent": 11,
  "workbench.tree.renderIndentGuides": "always",
  "workbench.colorCustomizations": {
    "tree.indentGuidesStroke": "#999999"
  },
  "workbench.editor.decorations.colors": true,
  "workbench.editor.pinnedTabSizing": "shrink",
  "workbench.editor.pinnedTabsOnSeparateRow": true,
  "workbench.editor.wrapTabs": true,

  // =====================================================================================
  // TERMINAL (External + Integrated)
  // =====================================================================================
  "terminal.external.osxExec": "Warp.app",
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorWidth": 2,
  "terminal.integrated.enableImages": true,
  "terminal.integrated.fontFamily": "MesloLGS NF",
  "terminal.integrated.fontWeightBold": "normal",
  "terminal.integrated.lineHeight": 1.1,
  "terminal.integrated.suggest.enabled": true,

  // =====================================================================================
  // EDITOR — CORE BEHAVIOR & APPEARANCE
  // =====================================================================================
  "breadcrumbs.enabled": true,
  "editor.accessibilitySupport": "off",
  "editor.bracketPairColorization.enabled": true,
  "editor.cursorBlinking": "expand",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorStyle": "line",
  "editor.detectIndentation": true,
  "editor.experimentalGpuAcceleration": "off",
  "editor.fontFamily": "'CaskaydiaCove Nerd Font Propo', 'FiraCode Nerd Font', 'Droid Sans Mono', Consolas, 'Courier New', monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 13,
  "editor.guides.bracketPairs": "active",
  "editor.linkedEditing": true,
  "editor.renderWhitespace": "boundary",
  "editor.rulers": [120],
  "editor.smoothScrolling": true,
  "editor.stickyScroll.enabled": true,
  "editor.tabSize": 2,
  // "editor.wordWrap": "wordWrapColumn",
  "editor.wordWrapColumn": 120,

  // =====================================================================================
  // EDITOR — MINIMAP
  // =====================================================================================
  "editor.minimap.enabled": true,
  "editor.minimap.maxColumn": 100,
  "editor.minimap.renderCharacters": false,
  "editor.minimap.showSlider": "always",
  "editor.minimap.size": "fill",

  // =====================================================================================
  // EDITOR — INTELLISENSE, HINTS & CODELENS
  // =====================================================================================
  "debug.console.fontFamily": "MesloLGS NF",
  "diffEditor.codeLens": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.find.autoFindInSelection": "multiline",
  "editor.inlayHints.enabled": "offUnlessPressed",
  "editor.inlineSuggest.suppressSuggestions": true,
  "editor.inlineSuggest.syntaxHighlightingEnabled": true,
  "javascript.referencesCodeLens.enabled": true,

  // =====================================================================================
  // EDITOR — FORMATTING & ON SAVE
  // =====================================================================================
  "editor.codeActionsOnSave": {
    "source.fixAll": "always"
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnPaste": false,
  "editor.formatOnSave": true,
  "editor.formatOnType": false,
  "notebook.defaultFormatter": "esbenp.prettier-vscode",

  // =====================================================================================
  // EDITOR — SEMANTIC TOKEN CUSTOMIZATION (Theme-Specific)
  // =====================================================================================
  "editor.semanticTokenColorCustomizations": {
    "[Nebula Oni (Cerberus)]": {
      "rules": {
        "function.declaration": {
          "foreground": "#2FDE73",
          "fontStyle": "bold italic"
        },
        "function": "#2FDE73"
      }
    }
  },

  // =====================================================================================
  // FILES — SAVE, ENCODING & TRIMMING
  // =====================================================================================
  "files.autoGuessEncoding": true,
  "files.autoSave": "off",
  "files.autoSaveDelay": 1000,
  "files.autoSaveWhenNoErrors": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "json.schemaDownload.enable": true,

  // =====================================================================================
  // FILES — EXCLUDE & WATCHER EXCLUDE
  // =====================================================================================
  "files.exclude": {
    "**/.trunk/*actions/": true,
    "**/.trunk/*logs/": true,
    "**/.trunk/*notifications/": true,
    "**/.trunk/*out/": true,
    "**/.trunk/*plugins/": true
  },
  "files.watcherExclude": {
    "**/.git/**": true,
    "**/.next/**": true,
    "**/.trunk/*actions/": true,
    "**/.trunk/*logs/": true,
    "**/.trunk/*notifications/": true,
    "**/.trunk/*out/": true,
    "**/.trunk/*plugins/": true,
    "**/coverage/**": true,
    "**/dist/**": true,
    "**/node_modules/**": true
  },

  // =====================================================================================
  // EXPLORER & SEARCH
  // =====================================================================================
  "explorer.compactFolders": false,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.db": "${capture}.${extname}-*",
    "*.db3": "${capture}.${extname}-*",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.s3db": "${capture}.${extname}-*",
    "*.sdb": "${capture}.${extname}-*",
    "*.sqlite": "${capture}.${extname}-*",
    "*.sqlite3": "${capture}.${extname}-*",
    "*.ts": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
    "tsconfig.json": "tsconfig.*.json"
  },
  "explorer.sortOrder": "type",
  "search.exclude": {
    "**/.next": true,
    "**/coverage": true,
    "**/dist": true,
    "**/node_modules": true
  },

  // =====================================================================================
  // GIT & GITHUB
  // =====================================================================================
  "git.allowForcePush": true,
  "git.autofetch": true,
  "git.autorefresh": true,
  "git.autoStash": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.mergeEditor": true,
  "git.showPushSuccessNotification": true,
  "git.useEditorAsCommitInput": false,
  "githubPullRequests.pullBranch": "never",

  // =====================================================================================
  // GITLENS
  // =====================================================================================
  "gitlens.advanced.messages": {
    "suppressLineUncommittedWarning": true,
    "suppressIntegrationDisconnectedTooManyFailedRequestsWarning": true
  },
  "gitlens.ai.gitkraken.model": "gemini:gemini-2.5-flash",
  "gitlens.ai.model": "gitkraken",
  "gitlens.ai.vscode.model": "copilot:gpt-4o",
  "gitlens.graph.dimMergeCommits": true,
  "gitlens.outputLevel": "error",
  "gitlens.rebaseEditor.ordering": "asc",
  "gitlens.views.repositories.showIncomingActivity": true,
  "gitlens.views.repositories.showStashes": true,
  "typescript.disableAutomaticTypeAcquisition": true,
  "typescript.experimental.useTsgo": true,
  "typescript.tsserver.maxTsServerMemory": 6144,
  "typescript.tsserver.nodePath": "node",
  "typescript.tsserver.useSyntaxServer": "auto",

  // =====================================================================================
  // TYPESCRIPT & JAVASCRIPT — INLAY HINTS
  // =====================================================================================
  "javascript.inlayHints.enumMemberValues.enabled": true,
  "javascript.inlayHints.functionLikeReturnTypes.enabled": true,
  "javascript.inlayHints.parameterTypes.enabled": true,
  "javascript.inlayHints.variableTypes.enabled": true,
  "typescript.inlayHints.enumMemberValues.enabled": true,
  "typescript.inlayHints.functionLikeReturnTypes.enabled": true,
  "typescript.inlayHints.parameterNames.enabled": "all",
  "typescript.inlayHints.parameterTypes.enabled": true,
  "typescript.inlayHints.propertyDeclarationTypes.enabled": true,
  "typescript.inlayHints.variableTypes.enabled": true,

  // =====================================================================================
  // GO TOOLING
  // =====================================================================================
  "go.alternateTools": {
    "customFormatter": "/Users/jacob.lecoq.ext/.local/share/mise/shims/gofmt"
  },
  "go.inlayHints.compositeLiteralTypes": true,
  "go.inlayHints.constantValues": true,
  "go.inlayHints.functionTypeParameters": true,
  "go.lintTool": "golangci-lint",
  "go.testFlags": ["-v"],
  "go.toolsManagement.autoUpdate": true,

  // =====================================================================================
  // LUA (Sumneko)
  // =====================================================================================
  "Lua.codeLens.enable": false,
  "Lua.hint.awaitPropagate": true,
  "Lua.hint.enable": true,
  "Lua.hint.setType": true,
  "Lua.semantic.keyword": true,
  "Lua.type.inferParamType": true,
  "Lua.workspace.library": [
    "~/.local/share/nvim/lazy/",
    "~/.local/share/nvim/mason"
  ],

  // =====================================================================================
  // PYTHON
  // =====================================================================================
  "python.defaultInterpreterPath": "/Users/lecoqjacob/.local/share/mise/installs/python/3.14.3/bin/python",
  "python.terminal.useEnvFile": true,

  // =====================================================================================
  // RUST
  // =====================================================================================
  "rust-analyzer.check.command": "clippy",

  // =====================================================================================
  // QUALITY / LINT
  // =====================================================================================
  "eslint.format.enable": true,
  "eslint.useESLintClass": true,
  "jest.runMode": "on-demand",

  // =====================================================================================
  // DEBUG
  // =====================================================================================
  "debug.javascript.unmapMissingSources": true,
  "debug.showBreakpointsInOverviewRuler": true,
  "debug.toolBarLocation": "commandCenter",
  "notebook.diff.overviewRuler": true,

  // =====================================================================================
  // HTTP & SECURITY
  // =====================================================================================
  "http.experimental.systemCertificatesV2": true,
  "http.proxyStrictSSL": false,
  "http.proxySupport": "fallback",
  "security.promptForLocalFileProtocolHandling": false,
  "security.promptForRemoteFileProtocolHandling": false,
  "security.workspace.trust.untrustedFiles": "open",

  // =====================================================================================
  // REMOTE SSH
  // =====================================================================================
  "remote.autoForwardPortsSource": "hybrid",
  "remote.SSH.remotePlatform": {
    "crow-wolf.exe.xyz": "linux",
    "eagle": "linux",
    "emerald": "linux",
    "emerald-loader.exe.xyz": "linux",
    "jade-harbor.exe.xyz": "linux",
    "jade-harbor.exe.xyz/": "linux",
    "meteor-edit.exe.xyz": "linux",
    "noon": "linux",
    "noon-disk.exe.xyz": "linux",
    "pulse": "linux",
    "pulse-sky": "linux",
    "pulsar-reef.exe.xyz": "linux",
    "pulsar-sky.exe.xyz": "linux",
    "ssh jade-harbor.exe.xyz": "linux",
    "switch-rain.exe.xyz": "linux",
    "trout-eagle.exe.xyz": "linux",
    "yankee": "linux",
    "yankee-jig.exe.xyz": "linux",
    "vs3.spacecats.dev": "linux",
    "safe-tide": "linux"
  },

  // =====================================================================================
  // GITHUB COPILOT
  // =====================================================================================
  "github.copilot.enable": {
    "*": false,
    "markdown": true,
    "plaintext": false,
    "scminput": false
  },

  // =====================================================================================
  // CURSOR AI
  // =====================================================================================
  "cursor.composer.queueMessageDefaultBehavior": "queue",
  "cursor.composer.shouldChimeAfterChatFinishes": true,
  "cursor.composer.usageSummaryDisplay": "always",
  "cursor.cpp.disabledLanguages": ["plaintext", "scminput"],
  "cursor.cpp.enablePartialAccepts": true,
  "cursor.enable_agent_window_setting": true,
  "cursor.terminal.usePreviewBox": true,
  "cursor.windowSwitcher.sidebarHoverCollapsed": true,
  "cursorStats.showDailyRemaining": true,
  "cursorStats.showProgressBars": true,
  "cursorStats.showTotalRequests": true,

  // =====================================================================================
  // GEMINI CODE ASSIST
  // =====================================================================================
  "geminicodeassist.displayInlineContextHint": false,
  "geminicodeassist.inlineSuggestions.enableAuto": false,
  "geminicodeassist.project": "citric-thought-vrqlm",

  // =====================================================================================
  // KILO CODE
  // =====================================================================================
  "kilo-code.allowedCommands": [
    "cd",
    "git",
    "git diff",
    "git log",
    "git show",
    "go",
    "make",
    "npm",
    "npm install",
    "npm run",
    "npm run test -- --silent --libs features-common-reporting -- ViewReport.spec.tsx",
    "npm test",
    "nx",
    "nx run",
    "tsc"
  ],
  "kilo-code.debug": false,
  "kilo-code.deniedCommands": [],

  // =====================================================================================
  // KIMI
  // =====================================================================================
  "kimi.alwaysExpandThinking": true,
  "kimi.yoloMode": true,

  // =====================================================================================
  // TRAYCER
  // =====================================================================================
  "traycer.additionalAgents": [
    "Amp",
    "Augment",
    "Claude Code",
    "Claude Code Extension",
    "Codex",
    "Codex Extension",
    "Export as Markdown",
    "Roo Code"
  ],
  "traycer.enableAutoAnalysis": false,
  "traycer.enableCommentsHighlighting": true,

  // =====================================================================================
  // THEMES & THEME EXTENSIONS
  // =====================================================================================
  "nebulaOni.update.restoreConfiguration": {
    "favoriteSettings": {
      "background": "Glacial Blue",
      "comments": "Dark Magenta",
      "favorite": "Nebula Oni (Pegasus)",
      "focusBorder": "ON",
      "fontStyle": "Italic",
      "highlight": "Ultra Violet",
      "main": "Sakura",
      "syntaxBrightness": "Dimmed"
    },
    "themeSettings": {
      "background": "Grey",
      "comments": "Dark Violet",
      "favorite": "OFF",
      "focusBorder": "ON",
      "fontStyle": "Italic",
      "highlight": "Ultra Violet",
      "main": "Bumblebee",
      "syntaxBrightness": "Normal"
    }
  },
  "oneDarkPro.bold": true,

  // =====================================================================================
  // MISCELLANEOUS EXTENSIONS
  // =====================================================================================
  "aws.cloudformation.telemetry.enabled": true,
  "database-client.autoSync": true,
  "evenBetterToml.formatter.alignComments": true,
  "evenBetterToml.formatter.alignEntries": true,
  "markdownlint.lintWorkspaceGlobs": [
    "**/*.{md,mkd,mdwn,mdown,markdown,markdn,mdtxt,mdtext,workbook}",
    "!**/*.code-search",
    "!**/bower_components",
    "!**/node_modules",
    "!**/.git",
    "!**/vendor",
    "!**/*.mdc"
  ],
  "playwright.reuseBrowser": true,
  "playwright.showTrace": false,
  "redhat.telemetry.enabled": false,
  "testExplorer.useNativeTesting": true,
  "totalTypeScript.hideAllTips": false,
  "totalTypeScript.hideBasicTips": true,
  "totalTypeScript.hiddenTips": [
    "as-const",
    "as-const-on-object",
    "awaited-utility-type",
    "conditional-type",
    "exclude-utility-type",
    "extract-utility-type",
    "generic-slots-in-functions",
    "in-operator-narrowing",
    "infer",
    "interface-with-generics",
    "interface-with-multiple-generics",
    "keyof",
    "mapped-type",
    "never-keyword",
    "non-null-expression",
    "nonnullable-utility-type",
    "omit-utility-type",
    "parameters-utility-type",
    "partial-utility-type",
    "passing-generics-to-types",
    "pick-utility-type",
    "record-utility-type",
    "readonly-utility-type",
    "remapping-in-mapped-type",
    "required-utility-type",
    "returntype-utility-type",
    "tuple-type",
    "type-alias-with-generics",
    "type-alias-with-multiple-generics",
    "type-predicate",
    "typeof",
    "nested-conditional-type"
  ],
  "update.releaseTrack": "prerelease",

  // =====================================================================================
  // LANGUAGE OVERRIDES — BY FILETYPE
  // =====================================================================================
  "[astro]": {
    "editor.defaultFormatter": "astro-build.astro-vscode"
  },
  "[cpp]": {
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
  },
  "[css]": {
    "editor.defaultFormatter": "denoland.vscode-deno"
  },
  "[dockercompose]": {
    "editor.autoIndent": "advanced",
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.insertSpaces": true,
    "editor.tabSize": 2
  },
  "[dotenv]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[go]": {
    "editor.defaultFormatter": "golang.go"
  },
  "[go.mod]": {
    "editor.defaultFormatter": "golang.go"
  },
  "[ignore]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.quickSuggestions": {
      "strings": true
    },
    "editor.suggest.insertMode": "replace"
  },
  "[lua]": {
    "editor.defaultFormatter": "JohnnyMorganz.stylua"
  },
  "[markdown]": {
    "editor.defaultFormatter": "trunk.io",
    "editor.unicodeHighlight.invisibleCharacters": true
  },
  "[plaintext]": {
    "editor.unicodeHighlight.invisibleCharacters": true
  },
  "[postcss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[python]": {
    "editor.defaultFormatter": "trunk.io"
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },
  "[shellscript]": {
    "editor.defaultFormatter": "mkhl.shfmt"
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[jinja-html]": {
    "editor.defaultFormatter": "monosans.djlint"
  },
  "cSpell.userWords": [
    "carc",
    "journalctl",
    "luxon",
    "rarc",
    "timesheet",
    "timesheets",
    "timespan"
  ],
  "makefile.configureOnOpen": false,
  "markdown.updateLinksOnFileMove.enabled": "prompt",
  "terminal.integrated.commandsToSkipShell": [
    "kilo-code.new.agentManagerOpen",
    "kilo-code.new.agentManager.showTerminal"
  ],
  "kilo-code.new.autocomplete.enableAutoTrigger": true,
  "kilo-code.new.autocomplete.enableSmartInlineTaskKeybinding": true,
  "kilo-code.new.autocomplete.enableChatAutocomplete": true,
  "kilo-code.new.browserAutomation.enabled": true,
