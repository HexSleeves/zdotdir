#!/bin/bash
{{- if eq .chezmoi.os "darwin" }}

# Setup 1Password CLI
# Idempotent script to configure 1Password with biometric authentication

set -euo pipefail

echo "Setting up 1Password CLI..."

# Check if op is installed
if ! command -v op >/dev/null 2>&1; then
    echo "1Password CLI not found. Installing via Homebrew..."
    if command -v brew >/dev/null 2>&1; then
        brew install --cask 1password-cli
    else
        echo "Homebrew not found. Please install 1Password CLI manually:"
        echo "  https://developer.1password.com/docs/cli/get-started/"
        exit 1
    fi
fi

# Check if 1Password app is installed
if ! command -v "1Password" >/dev/null 2>&1 && [[ ! -d "/Applications/1Password.app" ]]; then
    echo ""
    echo "1Password desktop app not found."
    echo "The 1Password CLI works best with the desktop app for biometric authentication."
    echo ""
    echo "Install from: https://1password.com/downloads/"
    echo "Or via Homebrew: brew install --cask 1password"
    echo ""
    read -rp "Continue without desktop app? (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 0
    fi
fi

# Enable biometric authentication (recommended for macOS)
echo ""
echo "Configuring biometric authentication..."
echo "This allows 1Password CLI to use Touch ID for authentication."
echo ""

# Check if biometric is already enabled
BIOMETRIC_STATUS=$(op account list --format json 2>/dev/null | jq -r '.[0].biometric // empty' 2>/dev/null || echo "")

if [[ "$BIOMETRIC_STATUS" == "enabled" ]]; then
    echo "Biometric authentication already enabled."
else
    echo "To enable biometric authentication:"
    echo "  1. Open 1Password desktop app"
    echo "  2. Go to Preferences > Developer"
    echo "  3. Enable 'Touch ID' or 'Biometric unlock'"
    echo "  4. Run: op signin --account <account-shorthand>"
    echo ""
fi

# Check if already signed in
ACCOUNT_LIST=$(op account list --format json 2>/dev/null || echo "[]")
ACCOUNT_COUNT=$(echo "$ACCOUNT_LIST" | jq 'length')

if [[ "$ACCOUNT_COUNT" -eq 0 ]]; then
    echo ""
    echo "No 1Password accounts configured."
    echo "To add an account:"
    echo "  op account add --address <subdomain>.1password.com --email <email>"
    echo ""
    echo "Example:"
    echo "  op account add --address my.1password.com --email user@example.com"
    echo ""
    echo "After adding your account, sign in with:"
    echo "  eval \$(op signin)"
    echo ""
else
    echo ""
    echo "1Password accounts configured:"
    echo "$ACCOUNT_LIST" | jq -r '.[] | "  - \(.shorthand) (\(.email))"'
    echo ""
    
    # Check if we have an active session
    if op user list --format json >/dev/null 2>&1; then
        echo "✓ Active session detected. 1Password is ready to use with chezmoi!"
    else
        echo "No active session. Sign in with:"
        echo "  eval \$(op signin)"
        echo ""
        echo "Or use biometric authentication (if enabled):"
        echo "  op signin --biometric"
    fi
fi

echo ""
echo "1Password setup complete!"
echo ""
echo "You can now use 1Password with chezmoi templates:"
echo '  {{ "{{" }} onepasswordRead "op://vault/item/field" {{ "}}" }}'
echo '  {{ "{{" }} (onepassword "item-uuid").fields[0].value {{ "}}" }}'
echo ""
echo "Useful commands:"
echo "  op account list           - List configured accounts"
echo "  op signin                 - Sign in to your account"
echo "  op signout                - Sign out of your account"
echo "  op item get <item>        - Get an item by name or UUID"
echo "  just 1p                   - See all 1Password commands"
{{- else if eq .chezmoi.os "linux" }}

# Setup 1Password CLI on Linux
# Uses biometric authentication or device authentication

set -euo pipefail

echo "Setting up 1Password CLI..."

# Check if op is installed
if ! command -v op >/dev/null 2>&1; then
    echo "1Password CLI not found. Installing..."
    
    # Download and install 1Password CLI
    ARCH=$(uname -m)
    case "$ARCH" in
        x86_64) ARCH="amd64" ;;
        aarch64|arm64) ARCH="arm64" ;;
        *) echo "Unsupported architecture: $ARCH"; exit 1 ;;
    esac
    
    cd /tmp
    curl -sSO https://cache.agilebits.com/dist/1P/op2/pkg/v2.30.3/op_linux_${ARCH}_v2.30.3.zip
    unzip -o op_linux_${ARCH}_v2.30.3.zip -d op
    sudo mv op/op /usr/local/bin/
    rm -rf op op_linux_${ARCH}_v2.30.3.zip
    cd - > /dev/null
fi

# Check if 1Password app is installed (optional on Linux)
if [[ ! -d "/opt/1Password" ]] && [[ ! -d "$HOME/.1password" ]]; then
    echo ""
    echo "Note: 1Password desktop app is recommended for biometric authentication."
    echo "Install from: https://1password.com/downloads/linux/"
    echo ""
fi

# Check if already signed in
ACCOUNT_LIST=$(op account list --format json 2>/dev/null || echo "[]")
ACCOUNT_COUNT=$(echo "$ACCOUNT_LIST" | jq 'length')

if [[ "$ACCOUNT_COUNT" -eq 0 ]]; then
    echo ""
    echo "No 1Password accounts configured."
    echo "To add an account:"
    echo "  op account add --address <subdomain>.1password.com --email <email>"
    echo ""
else
    echo ""
    echo "1Password accounts configured:"
    echo "$ACCOUNT_LIST" | jq -r '.[] | "  - \(.shorthand) (\(.email))"'
    echo ""
    
    # Check if we have an active session
    if op user list --format json >/dev/null 2>&1; then
        echo "✓ Active session detected. 1Password is ready to use with chezmoi!"
    else
        echo "No active session. Sign in with:"
        echo "  eval \$(op signin)"
    fi
fi

echo ""
echo "1Password setup complete!"
echo ""
echo "You can now use 1Password with chezmoi templates:"
echo '  {{ "{{" }} onepasswordRead "op://vault/item/field" {{ "}}" }}'
echo '  {{ "{{" }} (onepassword "item-uuid").fields[0].value {{ "}}" }}'
{{- end }}