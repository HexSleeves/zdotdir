#!/bin/sh

# Setup GPG Keys
# Idempotent script to setup GPG

echo "🔐 Setting up GPG keys..."

helper_path="{{ .chezmoi.sourceDir }}/dot_config/dotfiles/executable_export-keys.sh"
archive_path="{{ .chezmoi.sourceDir }}/bootstrap/gpg/gpg-keyring.tgz.gpg"
legacy_keyring_dir="$HOME/.local/share/gnupg/.exported-keyring"

# Ensure GPG is installed
if ! command -v gpg >/dev/null 2>&1; then
    echo "Installing GPG..."
    if command -v brew >/dev/null 2>&1; then
        brew install gnupg
    elif command -v apt-get >/dev/null 2>&1; then
        sudo apt-get install -y gnupg
    elif command -v pacman >/dev/null 2>&1; then
        sudo pacman -S --noconfirm gnupg
    else
        echo "❌ Cannot install GPG - no package manager found."
        exit 1
    fi
fi

# Ensure directories exist
mkdir -p ~/.local/share/gnupg/.exported-keyring

# Import keys if they exist
if [ -f "$archive_path" ]; then
    echo "Importing keys from encrypted chezmoi archive..."
    if [ ! -f "$helper_path" ]; then
        echo "❌ Missing helper script: $helper_path"
        exit 1
    fi

    bash "$helper_path" --import --chezmoi --archive "$archive_path"
    echo "✅ GPG keys imported from encrypted archive"
elif ls "$legacy_keyring_dir"/*.asc >/dev/null 2>&1; then
    echo "Importing keys from legacy exported keyring..."
    gpg --import "$legacy_keyring_dir"/*.asc 2>/dev/null || true

    if [ -f "$legacy_keyring_dir/ownertrust.txt" ]; then
        gpg --import-ownertrust "$legacy_keyring_dir/ownertrust.txt" 2>/dev/null || true
    fi
    echo "✅ GPG keys imported from legacy exported keyring"
else
    echo "ℹ️  No exported keys found to import."
fi
